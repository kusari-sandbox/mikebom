FROM rust:1.87-bookworm

# eBPF build dependencies + curl/jq for ad-hoc tooling inside the container.
RUN apt-get update && apt-get install -y \
    clang \
    llvm \
    libelf-dev \
    linux-headers-generic \
    pkg-config \
    libssl-dev \
    curl \
    ca-certificates \
    jq \
    dpkg-dev \
    && rm -rf /var/lib/apt/lists/*

# Install nightly toolchain for eBPF target and bpf-linker
RUN rustup toolchain install nightly \
    && rustup component add rust-src --toolchain nightly \
    && cargo +nightly install bpf-linker

WORKDIR /mikebom
COPY . .

# Build eBPF kernel programs first
RUN cargo run --package xtask -- ebpf 2>&1 || echo "eBPF build result: $?"

# Build the userspace binary
RUN cargo build --release 2>&1

# Run tests
RUN cargo test --workspace 2>&1
